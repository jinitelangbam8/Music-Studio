{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Playlist": {
      "title": "Playlist",
      "description": "User created playlists",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "songIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "userId"]
    },
    "Song": {
      "title": "Song",
      "description": "Music track information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "artist": { "type": "string" },
        "duration": { "type": "number" },
        "url": { "type": "string" },
        "thumbnail": { "type": "string" },
        "addedBy": { "type": "string" }
      },
      "required": ["title", "artist", "url"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/playlists/{playlistId}": {
      "schema": "Playlist",
      "description": "User playlists"
    },
    "/songs/{songId}": {
      "schema": "Song",
      "description": "Music tracks"
    }
  }
}
